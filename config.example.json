{
  "env": "development",
  "debug": true,
  "server": {
    "host": "127.0.0.1",
    "port": 8000,
    "workers": 1,
    "interface": "rsgi",
    "log_level": "info"
  },
  "security": {
    "secret_key": null,
    "enable_csrf": true,
    "enable_security_headers": true,
    "hsts_max_age": 31536000,
    "hsts_include_subdomains": true,
    "csp_policy": "default-src 'self'; object-src 'none'",
    "referrer_policy": "strict-origin-when-cross-origin",
    "coop_policy": "same-origin",
    "coep_policy": "require-corp",
    "cookie_secure": true,
    "cookie_httponly": true,
    "cookie_samesite": "Strict",
    "cookie_max_age": 3600,
    "session_storage_type": "file",
    "session_storage_path": null
  },
  "cors": {
    "enabled": false,
    "allow_origins": ["*"],
    "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "allow_headers": ["*"],
    "allow_credentials": false,
    "max_age": 86400
  },
  "static_files": {
    "enabled": true,
    "url_path": "/static",
    "directory": "static",
    "use_rust": true
  },
  "templates": {
    "directory": "templates",
    "use_rust": true,
    "auto_reload": false,
    "cache_size": 400
  },
  "tasks": {
    "enabled": true,
    "storage_type": "duckdb",
    "storage_path": null,
    "max_workers": 4,
    "default_priority": 5,
    "enable_retries": true,
    "max_retries": 3,
    "cleanup_days": 7
  },
  "rate_limit": {
    "enabled": false,
    "default_rate": 100,
    "default_period": 60,
    "storage_type": "memory"
  },
  "logging": {
    "level": "info",
    "format": "text",
    "enable_correlation_id": false,
    "log_file": null
  },
  "metrics": {
    "enabled": false,
    "export_type": "prometheus",
    "endpoint": "/metrics",
    "include_hostname": true
  },
  "custom": {}
}

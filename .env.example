# Environment Variables for Gobstopper Project
# Copy this to .env and fill in your actual values
# NEVER commit .env to git!

# PyPI API Tokens
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-YOUR-PRODUCTION-TOKEN-HERE
TWINE_TEST_USERNAME=__token__
TWINE_TEST_PASSWORD=pypi-YOUR-TEST-TOKEN-HERE

# Optional: Repository URLs (usually not needed)
# TWINE_REPOSITORY_URL=https://upload.pypi.org/legacy/

# GitHub Personal Access Token (for releases)
# GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Other project-specific secrets
# Add any other API keys or secrets your project needs here
